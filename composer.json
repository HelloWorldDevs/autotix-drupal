{
  "name": "autotix/drupal-module",
  "description": "Autotix Drupal module - sends watchdog errors to Autotix",
  "type": "drupal-module",
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0",
    "guzzlehttp/guzzle": "^7.0",
    "psr/log": "^3.0",
    "symfony/http-foundation": "^5.4 || ^6.0 || ^7.0",
    "symfony/dependency-injection": "^5.4 || ^6.0 || ^7.0"
  },
  "autoload": {
    "psr-4": {
      "Drupal\\autotix\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Drupal\\Tests\\autotix\\": "tests/"
    }
  }
}
