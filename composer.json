{
  "name": "autotix/drupal-module",
  "description": "Drupal module that captures watchdog errors and forwards them to the Autotix webhook for automated Jira/GitHub ticket creation and auto-fix PRs.",
  "type": "drupal-module",
  "license": "GPL-2.0-or-later",
  "homepage": "https://autotix.io",
  "authors": [
    {
      "name": "Hello World Devs",
      "email": "dev@helloworlddevs.com",
      "homepage": "https://helloworlddevs.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "drupal/core": "^10.3 || ^11.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5 || ^11.0",
    "guzzlehttp/guzzle": "^7.0",
    "psr/log": "^3.0",
    "symfony/http-foundation": "^5.4 || ^6.0 || ^7.0",
    "symfony/dependency-injection": "^5.4 || ^6.0 || ^7.0"
  },
  "autoload": {
    "psr-4": {
      "Drupal\\autotix\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Drupal\\Tests\\autotix\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  }
}
